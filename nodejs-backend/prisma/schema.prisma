generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Shift {
  id          Int          @id @default(autoincrement())
  shiftid     String       @unique
  latetiming  String
  halfday     String
  checkin     String
  checkout    String
  departments Department[]

  @@map("shifts")
}

model Department {
  id       Int    @id @default(autoincrement())
  name     String @unique
  shift_id Int?
  shift    Shift? @relation(fields: [shift_id], references: [id])
  users    User[]

  @@map("departments")
}

model User {
  id                 String             @id @unique
  name               String
  role               String             @default("employee")
  email              String?            @unique
  password_hash      String?
  monthly_salary     Float              @default(0.0)
  leave_bank         Int                @default(5)
  department_id      Int?
  created_at         DateTime           @default(now())
  attendance_logs    AttendanceLog[]
  attendance_records AttendanceRecord[]
  audit_logs         AuditLog[]
  commissions        Commission[]
  deductions         Deduction[]
  disputes_app       Dispute[]          @relation("DisputeApprover")
  disputes_req       Dispute[]          @relation("DisputeRequester")
  leaveBank          LeaveBank?
  leave_reviews      LeaveRequest[]     @relation("LeaveReviewer")
  leave_requests     LeaveRequest[]     @relation("LeaveRequester")
  monitoring_logs    MonitoringLog[]
  notifications      Notification[]
  salaries           Salary[]
  department         Department?        @relation(fields: [department_id], references: [id])

  @@map("users")
}

model AttendanceLog {
  id        Int      @id @default(autoincrement())
  user_id   String
  timestamp DateTime
  status    Int
  user      User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, timestamp, status])
  @@map("attendance_logs")
}

model Salary {
  id               Int      @id @default(autoincrement())
  user_id          String
  paid_salary      Float    @default(0.0)
  date             DateTime
  dispute_id       Int?
  payable_salary   Float    @default(0.0)
  deduction        Float    @default(0.0)
  deduction_reason String?  @default("absence")
  dispute          Dispute? @relation(fields: [dispute_id], references: [id])
  user             User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("salaries")
}

model Commission {
  id         Int      @id @default(autoincrement())
  user_id    String
  commission Float
  date       DateTime
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("commissions")
}

model Dispute {
  id              Int         @id @default(autoincrement())
  req_by          String
  approved_by     String?
  description     String?
  remarks         String?
  date_of_req     DateTime
  date_of_approve DateTime?
  status          String      @default("pending")
  category        String
  dispute_date    DateTime
  deductions      Deduction[]
  approver        User?       @relation("DisputeApprover", fields: [approved_by], references: [id])
  requester       User        @relation("DisputeRequester", fields: [req_by], references: [id], onDelete: Cascade)
  salaries        Salary[]

  @@map("disputes")
}

model AttendanceRecord {
  id             Int      @id @default(autoincrement())
  user_id        String
  status         String
  date           DateTime
  check_in_time  String?  @db.VarChar(5)
  check_out_time String?  @db.VarChar(5)
  is_late        Boolean  @default(false)
  is_halfday     Boolean  @default(false)
  user           User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, date])
  @@unique([user_id, date], map: "absence_records_user_id_date_key")
  @@map("attendance_records")
}

model LeaveBank {
  id               Int     @id @default(autoincrement())
  user_id          String  @unique
  leaves_remaining Int     @default(0)
  last_reset_month String?
  user             User    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("leave_bank")
}

model Deduction {
  id         Int      @id @default(autoincrement())
  user_id    String
  date       DateTime
  type       String
  amount     Float
  dispute_id Int?
  dispute    Dispute? @relation(fields: [dispute_id], references: [id])
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("deductions")
}

model Notification {
  id         Int      @id @default(autoincrement())
  user_id    String
  type       String
  message    String
  is_read    Boolean  @default(false)
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model Holiday {
  id   Int      @id @default(autoincrement())
  name String
  date DateTime @unique

  @@map("holidays")
}

model LeaveRequest {
  id          Int      @id @default(autoincrement())
  user_id     String
  start_date  DateTime
  end_date    DateTime
  reason      String
  status      String   @default("pending")
  reviewed_by String?
  created_at  DateTime @default(now())
  reviewer    User?    @relation("LeaveReviewer", fields: [reviewed_by], references: [id])
  user        User     @relation("LeaveRequester", fields: [user_id], references: [id], onDelete: Cascade)

  @@map("leave_requests")
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  user_id    String?
  action     String
  details    String?
  created_at DateTime @default(now())
  user       User?    @relation(fields: [user_id], references: [id])

  @@map("audit_logs")
}

model MonitoringLog {
  id             Int      @id @default(autoincrement())
  user_id        String?
  app_name       String
  timestamp      DateTime
  screenshot_b64 String?
  created_at     DateTime @default(now())
  user           User?    @relation(fields: [user_id], references: [id])

  @@map("monitoring_logs")
}
