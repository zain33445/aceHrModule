generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Shift {
  id          Int          @id @default(autoincrement())
  shiftid     String       @unique
  latetiming  String
  halfday     String
  checkin     String
  checkout    String
  departments Department[]

  @@map("shifts")
}

model Department {
  id       Int     @id @default(autoincrement())
  name     String  @unique
  shift_id Int?
  lead_id  String?
  lead     User?   @relation("DepartmentLead", fields: [lead_id], references: [id])
  shift    Shift?  @relation(fields: [shift_id], references: [id])
  users    User[]

  @@map("departments")
}

model User {
  id                  String              @id @unique
  username            String?             @unique
  name                String
  role                String              @default("employee")
  email               String?             @unique
  password_hash       String?
  monthly_salary      Float               @default(0.0)
  leave_bank          Int                 @default(5)
  department_id       Int?
  created_at          DateTime            @default(now())
  agent_token         AgentToken?
  attendance_logs     AttendanceLog[]
  attendance_records  AttendanceRecord[]
  audit_logs          AuditLog[]
  commissions         Commission[]
  deductions          Deduction[]
  led_departments     Department[]        @relation("DepartmentLead")
  dispute_histories   DisputeHistory[]    @relation("HistoryActor")
  disputes_admin      Dispute[]           @relation("DisputeAdminApprover")
  disputes_app        Dispute[]           @relation("DisputeApprover")
  disputes_lead       Dispute[]           @relation("DisputeLeadApprover")
  disputes_req        Dispute[]           @relation("DisputeRequester")
  leaveBank           LeaveBank?
  leave_reviews       LeaveRequest[]      @relation("LeaveReviewer")
  leave_requests      LeaveRequest[]      @relation("LeaveRequester")
  monitoring_logs     MonitoringLog[]
  notifications       Notification[]
  created_schedules   RecordingSchedule[] @relation("AdminCreatedSchedules")
  recording_schedules RecordingSchedule[] @relation("EmployeeSchedules")
  created_sessions    RecordingSession[]  @relation("AdminCreatedSessions")
  recording_sessions  RecordingSession[]  @relation("EmployeeRecordings")
  salaries            Salary[]
  department          Department?         @relation(fields: [department_id], references: [id])

  @@map("users")
}

model AttendanceLog {
  id        Int      @id @default(autoincrement())
  user_id   String
  timestamp DateTime
  status    Int
  user      User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, timestamp, status])
  @@map("attendance_logs")
}

model Salary {
  id               Int      @id @default(autoincrement())
  user_id          String
  paid_salary      Float    @default(0.0)
  date             DateTime
  dispute_id       Int?
  payable_salary   Float    @default(0.0)
  deduction        Float    @default(0.0)
  deduction_reason String?  @default("absence")
  dispute          Dispute? @relation(fields: [dispute_id], references: [id])
  user             User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("salaries")
}

model Commission {
  id         Int      @id @default(autoincrement())
  user_id    String
  commission Float
  date       DateTime
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("commissions")
}

model Dispute {
  id                Int              @id @default(autoincrement())
  req_by            String
  approved_by       String?
  description       String?
  remarks           String?
  date_of_req       DateTime
  date_of_approve   DateTime?
  status            String           @default("pending")
  category          String
  dispute_date      DateTime
  admin_approved_at DateTime?
  admin_approved_by String?
  admin_remarks     String?
  admin_status      String           @default("pending")
  deleted_at        DateTime?
  final_status      String           @default("pending")
  is_deleted        Boolean          @default(false)
  is_escalated      Boolean          @default(false)
  lead_approved_at  DateTime?
  lead_approved_by  String?
  lead_remarks      String?
  lead_status       String           @default("pending")
  salary_restored   Boolean          @default(false)
  updated_at        DateTime         @updatedAt
  deductions        Deduction[]
  history           DisputeHistory[]
  adminApprover     User?            @relation("DisputeAdminApprover", fields: [admin_approved_by], references: [id])
  approver          User?            @relation("DisputeApprover", fields: [approved_by], references: [id])
  leadApprover      User?            @relation("DisputeLeadApprover", fields: [lead_approved_by], references: [id])
  requester         User             @relation("DisputeRequester", fields: [req_by], references: [id], onDelete: Cascade)
  salaries          Salary[]

  @@map("disputes")
}

model DisputeHistory {
  id         Int      @id @default(autoincrement())
  dispute_id Int
  actor_id   String
  action     String
  remarks    String?
  metadata   Json?
  created_at DateTime @default(now())
  actor      User     @relation("HistoryActor", fields: [actor_id], references: [id])
  dispute    Dispute  @relation(fields: [dispute_id], references: [id], onDelete: Cascade)

  @@map("dispute_history")
}

model AttendanceRecord {
  id             Int      @id @default(autoincrement())
  user_id        String
  status         String
  date           DateTime
  check_in_time  String?  @db.VarChar(5)
  check_out_time String?  @db.VarChar(5)
  is_late        Boolean  @default(false)
  is_halfday     Boolean  @default(false)
  user           User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, date])
  @@unique([user_id, date], map: "absence_records_user_id_date_key")
  @@map("attendance_records")
}

model LeaveBank {
  id               Int     @id @default(autoincrement())
  user_id          String  @unique
  leaves_remaining Float   @default(0)
  last_reset_month String?
  user             User    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("leave_bank")
}

model Deduction {
  id         Int      @id @default(autoincrement())
  user_id    String
  date       DateTime
  type       String
  amount     Float
  dispute_id Int?
  dispute    Dispute? @relation(fields: [dispute_id], references: [id])
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("deductions")
}

model Notification {
  id         Int      @id @default(autoincrement())
  user_id    String
  type       String
  message    String
  is_read    Boolean  @default(false)
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model Holiday {
  id     Int      @id @default(autoincrement())
  name   String
  date   DateTime @unique
  status String   @default("pending")

  @@map("holidays")
}

model LeaveRequest {
  id          Int      @id @default(autoincrement())
  user_id     String
  start_date  DateTime
  end_date    DateTime
  reason      String
  status      String   @default("pending")
  reviewed_by String?
  created_at  DateTime @default(now())
  reviewer    User?    @relation("LeaveReviewer", fields: [reviewed_by], references: [id])
  user        User     @relation("LeaveRequester", fields: [user_id], references: [id], onDelete: Cascade)

  @@map("leave_requests")
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  user_id    String?
  action     String
  details    String?
  created_at DateTime @default(now())
  user       User?    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("audit_logs")
}

model MonitoringLog {
  id             Int      @id @default(autoincrement())
  user_id        String?
  app_name       String
  timestamp      DateTime
  screenshot_b64 String?
  created_at     DateTime @default(now())
  user           User?    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("monitoring_logs")
}

model AgentToken {
  id         Int       @id @default(autoincrement())
  user_id    String    @unique
  token      String    @unique
  created_at DateTime  @default(now())
  last_seen  DateTime?
  user       User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("agent_tokens")
}

model RecordingSession {
  id         String           @id @default(uuid())
  user_id    String
  status     String           @default("pending")
  started_at DateTime?
  ended_at   DateTime?
  file_path  String?
  created_by String
  created_at DateTime         @default(now())
  updated_at DateTime         @updatedAt
  chunks     RecordingChunk[]
  creator    User             @relation("AdminCreatedSessions", fields: [created_by], references: [id])
  employee   User             @relation("EmployeeRecordings", fields: [user_id], references: [id], onDelete: Cascade)

  @@map("recording_sessions")
}

model RecordingChunk {
  id          String           @id @default(uuid())
  session_id  String
  chunk_index Int
  file_path   String
  file_size   Int              @default(0)
  uploaded_at DateTime         @default(now())
  session     RecordingSession @relation(fields: [session_id], references: [id], onDelete: Cascade)

  @@unique([session_id, chunk_index])
  @@map("recording_chunks")
}

model RecordingSchedule {
  id         Int      @id @default(autoincrement())
  user_id    String
  cron_expr  String
  action     String
  enabled    Boolean  @default(true)
  created_by String
  created_at DateTime @default(now())
  creator    User     @relation("AdminCreatedSchedules", fields: [created_by], references: [id])
  employee   User     @relation("EmployeeSchedules", fields: [user_id], references: [id], onDelete: Cascade)

  @@map("recording_schedules")
}
