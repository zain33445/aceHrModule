{
  "name": "acehrm",
  "private": true,
  "version": "1.0.9",
  "type": "module",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron": "electron .",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "@emotion/is-prop-valid": "^1.4.0",
    "axios": "^1.13.6",
    "chart.js": "^4.5.1",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.3",
    "framer-motion": "^12.36.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.2",
    "recharts": "^3.8.0",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.27",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "vite": "^6.2.1"
  },
  "build": {
    "appId": "com.ace.app",
    "productName": "aceHRM",
    "files": [
      "dist_build/**/*",
      "electron/**/*",
      "main.js",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "asar": true,
    "icon": "public/aceLogo.png",
    "publish": [
      {
        "provider": "github",
        "owner": "zain33445",
        "repo": "aceHrModule"
      }
    ],
    "forceCodeSigning": false,
    "win": {
      "target": "nsis",
      "icon": "public/aceLogo.png",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
